APP_NAME="Technical Notes API"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# Neon pooled runtime connection. The app automatically normalizes postgresql:// to postgresql+asyncpg://.
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# Optional direct/sync URL used by Alembic. If omitted, the app derives it from DATABASE_URL.
ALEMBIC_DATABASE_URL=postgresql+psycopg://user:password@host/dbname?ssl=require

# Security
ADMIN_TOKEN=replace-with-a-long-random-secret-at-least-16-chars
CORS_ORIGINS=http://localhost:5173,https://shelendra.com,https://notes.shelendra.com
TRUSTED_HOSTS=localhost,127.0.0.1,*.onrender.com,shelendra.com,notes.shelendra.com

# Performance / API shape
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800
JSON_RESPONSE_CACHE_SECONDS=60
NAV_CACHE_SECONDS=300
TOPIC_CACHE_SECONDS=900
MAX_PAGE_SIZE=100
DEFAULT_PAGE_SIZE=30
BOOTSTRAP_TOPIC_LIMIT=500
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Optional Redis cache. Leave empty on Render free unless you add Redis.
REDIS_URL=

